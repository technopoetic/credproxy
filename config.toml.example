# credproxy global configuration
# Copy to ~/.config/credproxy/config.toml and fill in your values
# Project-specific overrides go in .credproxy.toml at the project root

# Global env vars (always injected, unless overridden by profile)
[env]
TERM = "xterm-256color"

# Global host config (used when no profile is active)
[hosts."api.github.com"]
credential = "op://Personal/github-pat/token"

[hosts."api.stripe.com"]
credential = "op://Personal/stripe-default/key"

# Profile definitions
# Select with: credproxy --profile staging <command>

[profiles.staging.hosts."api.stripe.com"]
credential = "op://Personal/stripe-test/key"

[profiles.staging.env]
RAILS_ENV = "staging"
PORT = "3000"

[profiles.production.hosts."api.stripe.com"]
credential = "op://Personal/stripe-live/key"

[profiles.production.env]
RAILS_ENV = "production"
PORT = "443"

# Example credproxy configuration
# Copy to ~/.config/credproxy/credentials.toml and fill in your values

allowed_hosts = [
    "api.anthropic.com",
    "api.github.com",
    "api.stripe.com",
]

[credentials]
anthropic_key = "op://Personal/anthropic-api-key/secret"
github_pat = "op://Personal/github-pat/token"
stripe_key = "op://Business/stripe-live/key"